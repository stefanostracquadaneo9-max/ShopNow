NODE_ENV=production
PORT=3000

# Dati persistenti sulla VM Oracle
DB_PATH=/var/lib/shopnow/app.db
UPLOADS_DIR=/var/lib/shopnow/uploads

# Usa il dominio definitivo con https, ad esempio https://shopnow.tuodominio.it
PUBLIC_SITE_URL=https://TUO_DOMINIO

# Admin iniziale/sincronizzato
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=CAMBIA_QUESTA_PASSWORD

# Stripe
STRIPE_PUBLIC_KEY=pk_test_o_live_...
STRIPE_SECRET_KEY=sk_test_o_live_...
ALLOW_TEST_CHECKOUT_BYPASS=false

# Email Gmail SMTP
EMAIL_SERVICE=gmail
EMAIL_USER=tuo-account@gmail.com
EMAIL_PASSWORD=password_app_google
EMAIL_FROM=tuo-account@gmail.com
ADDRESS_LOOKUP_CONTACT_EMAIL=tuo-account@gmail.com

# Auto-fill indirizzi
ADDRESS_LOOKUP_CACHE_TTL_MS=21600000
ADDRESS_LOOKUP_TIMEOUT_MS=8000
ADDRESS_LOOKUP_USER_AGENT=ShopNow/1.0 (address-autofill; tuo-account@gmail.com)
